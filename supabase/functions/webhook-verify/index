/**
 * صحتنا - Webhook Verification Edge Function
 *
 * يتحقق من توقيع webhooks الواردة من ZainCash / FastPay / WhatsApp
 * باستخدام HS256 قبل معالجة الطلب.
 *
 * Usage:
 *   POST /functions/v1/webhook-verify
 *   Headers: X-Signature: <hmac_sha256_hex>
 *   Body: { "provider": "zaincash", "payload": {...}, "signature": "..." }
 */

const corsHeaders = {
  "Access-Control-Allow-Origin": "*",
  "Access-Control-Allow-Headers": "authorization, x-client-info, apikey, content-type",
  "Access-Control-Allow-Methods": "POST, OPTIONS",
};

/**
 * Verify HMAC-SHA256 signature
 */
async function verifySignature(
  payload: string,
  signature: string,
  secret: string
): Promise<boolean> {
  const encoder = new TextEncoder();
  const key = await crypto.subtle.importKey(
    "raw",
    encoder.encode(secret),
    { name: "HMAC", hash: "SHA-256" },
    false,
    ["sign", "verify"]
  );

  const sigBytes = new Uint8Array(
    signature.match(/.{1,2}/g)?.map((byte) => parseInt(byte, 16)) ?? []
  );

  return crypto.subtle.verify(
    "HMAC",
    key,
    sigBytes,
    encoder.encode(payload)
  );
}

Deno.serve(async (req) => {
  if (req.method === "OPTIONS") {
    return new Response("ok", { headers: corsHeaders });
  }

  if (req.method !== "POST") {
    return new Response(
      JSON.stringify({ error: "Method not allowed" }),
      { status: 405, headers: { ...corsHeaders, "Content-Type": "application/json" } }
    );
  }

  try {
    const { provider, payload, signature } = await req.json();

    if (!provider || !payload || !signature) {
      return new Response(
        JSON.stringify({ error: "provider, payload, and signature are required" }),
        { status: 400, headers: { ...corsHeaders, "Content-Type": "application/json" } }
      );
    }

    // Get the webhook secret from environment variables
    // Each provider has its own secret
    const secretMap: Record<string, string> = {
      zaincash: Deno.env.get("ZAINCASH_WEBHOOK_SECRET") ?? "",
      fastpay: Deno.env.get("FASTPAY_WEBHOOK_SECRET") ?? "",
      whatsapp: Deno.env.get("WHATSAPP_WEBHOOK_SECRET") ?? "",
    };

    const secret = secretMap[provider.toLowerCase()];

    if (!secret) {
      console.error(`Unknown provider: ${provider}`);
      return new Response(
        JSON.stringify({ valid: false, error: "Unknown provider" }),
        { status: 400, headers: { ...corsHeaders, "Content-Type": "application/json" } }
      );
    }

    const payloadStr = typeof payload === "string" ? payload : JSON.stringify(payload);
    const isValid = await verifySignature(payloadStr, signature, secret);

    if (!isValid) {
      console.warn(`Invalid signature from ${provider}`);
      return new Response(
        JSON.stringify({ valid: false, error: "Invalid signature" }),
        { status: 401, headers: { ...corsHeaders, "Content-Type": "application/json" } }
      );
    }

    // Signature is valid — process the webhook
    // TODO: Handle the verified payload (e.g., update payment status)
    console.log(`✅ Valid webhook from ${provider}`);

    return new Response(
      JSON.stringify({ valid: true, provider }),
      { status: 200, headers: { ...corsHeaders, "Content-Type": "application/json" } }
    );
  } catch (err) {
    console.error("Webhook verification error:", err);
    return new Response(
      JSON.stringify({ error: "Internal server error" }),
      { status: 500, headers: { ...corsHeaders, "Content-Type": "application/json" } }
    );
  }
});